# Meta Graph API
META_ACCESS_TOKEN=your_long_lived_access_token_here
META_IG_USER_ID=your_instagram_business_account_id

# Anthropic (reuses Claude Code CLI credentials if ANTHROPIC_API_KEY is already set)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Image Generation
IMAGE_PROVIDER=huggingface          # options: huggingface | replicate | local_sd | cloudinary
HF_API_TOKEN=your_huggingface_token_here

# Optional: Replicate (only if IMAGE_PROVIDER=replicate)
# REPLICATE_API_TOKEN=your_replicate_token_here

# Optional: Cloudinary (only if publisher.image_hosting=cloudinary in config.yml)
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
